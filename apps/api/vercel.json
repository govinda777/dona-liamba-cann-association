{
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=api",
  "outputDirectory": "dist",
  "regions": ["gru1"],
  "functions": {
    "src/**": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://dona-liamba.com" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" }
      ]
    }
  ]
}
